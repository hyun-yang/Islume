# ===== Islume environment variables =====
# Copy this file to .env and fill in real values.
# `.env` is gitignored — never commit secrets.

# ----- Infrastructure (required) -----
DATABASE_URL=postgresql+asyncpg://islume:dev_only_password@localhost:5432/islume_dev
REDIS_URL=redis://localhost:6379/0

# ----- LLM providers (set at least one) -----
# Anthropic (default provider)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# OpenAI (optional)
OPENAI_API_KEY=

# Google Gemini (optional)
GEMINI_API_KEY=

# Ollama — local LLM runtime (optional)
OLLAMA_BASE_URL=http://localhost:11434

# Sakana AI — OpenAI-compatible endpoint (optional)
SAKANA_AI_API_KEY=
SAKANA_BASE_URL=https://api.sakana.ai/v1

# ----- Model selection -----
# Comma-separated; first entry is the default offered to users.
ANTHROPIC_MODELS=claude-sonnet-4-5,claude-haiku-4-5
OPENAI_MODELS=
GEMINI_MODELS=
OLLAMA_MODELS=
SAKANA_MODELS=

# Internal system calls (similarity scoring, affinity checks).
# Keep this cheap — Haiku is plenty.
SYSTEM_LLM_MODEL=claude-haiku-4-5
MAX_SEMANTIC_PAIRS=20

# Explicit default chat model for agents without a preferred_model.
# Empty falls back to the first entry of the model lists above.
DEFAULT_CHAT_MODEL=

# ----- Wallet -----
# Hex-encoded 32-byte key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
WALLET_MASTER_KEY=REPLACE_ME_WITH_64_HEX_CHARS
WALLET_SERVICE_URL=http://localhost:8004

# ----- App -----
LOG_LEVEL=INFO
ENVIRONMENT=development

# ----- Langfuse / OpenTelemetry (optional observability) -----
# Leave keys empty to disable LLM trace export.
LANGFUSE_HOST=http://localhost:3100
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
OTEL_SERVICE_NAME=islume
OTEL_ENABLED=true
