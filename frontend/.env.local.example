# ===== Islume frontend environment =====
# Copy to .env.local and adjust as needed.
# Only NEXT_PUBLIC_* vars are exposed to the browser.

# UI default language: en | ko | ja
# Overridden at runtime by ./scripts/start_all.sh --lang <code>.
NEXT_PUBLIC_DEFAULT_LOCALE=en

# MapLibre style URL (optional). Falls back to a built-in demo style if unset.
# Example: https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_MAP_STYLE_URL=

# Direct WebSocket URL for the gateway (optional).
# Leave empty to use the page-origin default (ws://<host>:8002).
NEXT_PUBLIC_WS_DIRECT_URL=
